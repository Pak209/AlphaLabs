# ===========================================================================
# OLD MAC (PRODUCTION SERVER) .env CHECKLIST
# ---------------------------------------------------------------------------
# The old Mac keeps its OWN .env (chmod 600); deploy never overwrites it. This
# template documents the variable NAMES the server needs — fill values locally
# on the server, never commit real secrets. No live trading: keep the scheduler
# in dry_run and leave automation-paper flags off.
#
# REQUIRED on the old Mac:
#   POLYGON_API_KEY                      (Polygon source capture + futures/options)
#   SEC_USER_AGENT                       (SEC EDGAR contact string)
#   ALPHALAB_SCHEDULER_MODE=dry_run      (NO orders; this is the safe default)
#   ALPHA_LAB_DB_PATH=/Users/<old-mac-user>/AlphaLab/alpha_lab/data/alpha_lab.sqlite3
#   POLYGON_FUTURES_BASE_URL
#   POLYGON_FUTURES_AGGS_PATH
#   POLYGON_FUTURES_MIN_INTERVAL_SEC
#   POLYGON_OPTIONS_BASE_URL
#   POLYGON_OPTIONS_MIN_INTERVAL_SEC
#   POLYGON_OPTIONS_WATCHLIST
#   POLYGON_OPTIONS_PREVIEW_LIMIT
#   POLYGON_OPTIONS_MAX_CONTRACTS_PER_SIDE
#   ALPHALAB_API_TOKEN                   (only if dashboard API protection is on)
#
# OPTIONAL (leave blank to keep the provider disabled):
#   BENZINGA_API_KEY  TIINGO_API_KEY  NEWSFILTER_API_KEY
#
# Verify on the server with:  ./scripts/verify_old_mac_runtime.sh
# ===========================================================================

ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# SINGLE SOURCE OF TRUTH. The old Mac owns the one canonical SQLite file; every
# entry point (dashboard, scheduler, reports, diagnostics) resolves it through
# this var, so there is never a second, split-brain DB. On the dev Mac the
# relative default is fine; the SERVER can pin the ABSOLUTE path below manually.
#   Old Mac: ALPHA_LAB_DB_PATH=/Users/<old-mac-user>/AlphaLab/alpha_lab/data/alpha_lab.sqlite3
# Verify the active path / counts / scheduler heartbeat any time with:
#   .venv/bin/python -m alpha_lab.db_status          (or: npm run db:status)
#   curl -s http://127.0.0.1:8787/api/health         (db_path + db_inode fields)
# Do NOT point this at a network/SMB/NFS mount — live SQLite writes over a network
# share corrupt the file. The phone + dev Mac reach the data through the old Mac's
# API over Tailscale/LAN (see docs/server-setup.md), never by copying DB files.
ALPHA_LAB_DB_PATH=alpha_lab/data/alpha_lab.sqlite3

# Scheduler execution mode. dry_run = generate + score ideas, place NO orders
# (the production-safe default). 'paper' is opt-in and additionally gated by
# ALPHALAB_ALLOW_AUTOMATION_PAPER_TRADES. Leave this dry_run on the old Mac.
ALPHALAB_SCHEDULER_MODE=dry_run

# Paper execution controls. These still refuse live Alpaca endpoints.
ALPHALAB_ALLOW_AUTOMATION_PAPER_TRADES=false
ALPHALAB_ALLOW_MANUAL_PAPER_TRADES=true
ALPHALAB_REQUIRE_PAPER_APPROVAL=true

# Live catalyst/news source providers. Leave blank to keep a provider disabled.
# SEC asks automated clients to send a descriptive User-Agent with contact info.
SEC_USER_AGENT=AlphaLab/0.1 your_email@example.com
SEC_LOOKBACK_DAYS=3
SEC_MAX_SYMBOLS=25
POLYGON_API_KEY=
BENZINGA_API_KEY=
TIINGO_API_KEY=
NEWSFILTER_API_KEY=
CATALYST_WATCHLIST=NVDA,AMD,MSFT,META,AAPL,AMZN,GOOGL,TSLA,COIN,MSTR,SMCI,PLTR,ORCL,AVGO
NEWSFILTER_LOOKBACK_HOURS=6

# Overnight Futures Pulse (read-only). Uses POLYGON_API_KEY above against the
# Polygon/Massive Futures v1 aggregates endpoint (window bounds are nanosecond
# epochs on window_start; the agent builds the front-month contract ticker, e.g.
# ESM6, itself). Override base URL/path only for a different host or symbology.
# Leave POLYGON_API_KEY blank to keep the pulse in "no data" (neutral) mode.
POLYGON_FUTURES_BASE_URL=https://api.polygon.io
POLYGON_FUTURES_AGGS_PATH=/futures/v1/aggs/{ticker}
# The free "Futures Basic" plan allows ~5 requests/minute. Set a per-request
# floor (seconds) so a full 12-contract board throttles instead of getting 429'd.
# 13 keeps a full board comfortably under the cap (~2.5 min/run). 0 = no throttle.
POLYGON_FUTURES_MIN_INTERVAL_SEC=0

# Options flow uses the same Polygon key on the free "Options Basic" tier. Only
# reference contracts + per-contract EOD aggregates are entitled (the chain
# snapshot with open interest is not), so the live provider derives call/put
# volume + a trailing call-volume multiple from a near-the-money window. The
# per-request floor (seconds) throttles a multi-contract chain under the 5/min
# cap; this is built for the offline overnight pull, not interactive use. 0 = off.
POLYGON_OPTIONS_BASE_URL=https://api.polygon.io
POLYGON_OPTIONS_MIN_INTERVAL_SEC=0
POLYGON_OPTIONS_WATCHLIST=SPY,QQQ,NVDA
POLYGON_OPTIONS_PREVIEW_LIMIT=3
POLYGON_OPTIONS_MAX_CONTRACTS_PER_SIDE=4

# Optional LLM analyst layer. Defaults off and never executes trades directly.
ANTHROPIC_API_KEY=
LLM_ANALYST_ENABLED=false
LLM_MODEL=claude-3-5-sonnet-latest
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.2

# ChatGPT (OpenAI) is the automatic fallback when Claude is unavailable. Leave
# OPENAI_API_KEY blank to disable the fallback. LLM_PRIMARY picks which provider
# is tried first: "anthropic" (default) or "openai".
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PRIMARY=anthropic

# Remote action gate (opt-in). When set, every mutating request (approve /
# paper-trade / import / chat) must send 'Authorization: Bearer <this token>'.
# Reads stay open so the dashboard still renders. Leave blank for open localhost
# dev. Generate a strong value, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ALPHALAB_API_TOKEN=

# ===========================================================================
# NOTIFICATIONS (PWA Web Push + Twilio SMS) — all OFF by default
# ---------------------------------------------------------------------------
# Nothing leaves the box until you both (a) opt in per-channel in the dashboard
# notification settings AND (b) set the env below. The master dry-run switch
# defaults ON, so deliveries are only LOGGED to the notification_audit table.
# Flip ALERT_DELIVERY_DRY_RUN=false only once channels are configured & tested.
ALERT_DELIVERY_DRY_RUN=true

# The /api/notifications/test endpoint is dry-run only (audited, nothing sent) and
# REFUSES a real send unless this is true. Keep it off so the normal API can never
# push an arbitrary real SMS/push; flip on only for a deliberate, supervised test.
ALPHALAB_ALLOW_REAL_NOTIFICATION_TESTS=false

# --- Twilio SMS (optional). SMS stays disabled unless ALERT_SMS_ENABLED=true
# AND all three Twilio values are present. By default SMS only fires for
# APPROVAL_REQUIRED and RISK_KILL (see notification preferences sms_min_level).
# The auth token is a secret — never commit it or print it.
ALERT_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Fallback recipient if no sms_phone_number is set in notification preferences.
ALERT_SMS_TO_NUMBER=

# --- Web Push (VAPID). Required for PWA push. Generate a keypair once, e.g.:
#   python3 -c "from py_vapid import Vapid01 as V; v=V(); v.generate_keys(); \
#     import base64; print(v.private_pem().decode()); print(v.public_key)"
# (or any VAPID generator). The PUBLIC key is exposed to the browser; the
# PRIVATE key never leaves the server. pywebpush must be installed to send.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alerts@alphalab.local

# AUDIT-METADATA ONLY — this does NOT enable or gate live execution. It is read
# solely to stamp the live_mode column on approval_decisions so the audit trail
# records the posture at sign-off time. Live (non-paper) execution is not
# implemented and is blocked structurally at the broker layer (AlpacaClient only
# permits the paper-api.alpaca.markets endpoint), so no order can reach a live
# account regardless of this value. Leave it false.
ALPHALAB_ALLOW_LIVE_EXECUTION=false
