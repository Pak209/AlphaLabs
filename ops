cmd_doctor() {
  load_conf
  step "Tailscale + SSH readiness (target: $TARGET)"

  # --- dev-Mac side ---
  if command -v tailscale >/dev/null 2>&1; then
    ok "tailscale installed on this Mac"
    local DEV_IP; DEV_IP="$(tailscale ip -4 2>/dev/null | head -n1 || true)"
    if [ -n "$DEV_IP" ]; then ok "this Mac is connected to the tailnet ($DEV_IP)"
    else warn "tailscale present but no tailnet IP — run: tailscale up"; fi
  else
    warn "tailscale not installed on this Mac — install from https://tailscale.com/download (or 'brew install tailscale')"
  fi
  if [ -n "${TAILSCALE_HOST:-}" ]; then ok "using TAILSCALE_HOST=$TAILSCALE_HOST"
  else warn "TAILSCALE_HOST not set in server.conf; using SERVER_HOST=${SERVER_HOST:-<unset>} (LAN only)"; fi

  # --- SSH reachability (proves Remote Login is enabled on the server) ---
  if rsh "echo ok" >/dev/null 2>&1; then
    ok "SSH reachable — Remote Login is enabled on the server"
  else
    err "SSH to $TARGET failed (Remote Login off, host down, or wrong host/user)"
    print "  Test directly:  ssh $TARGET 'echo ok'"
    exit 1
  fi

  # --- server side ---
  local HOSTN; HOSTN="$(rsh 'scutil --get LocalHostName 2>/dev/null || hostname -s' 2>/dev/null)"
  ok "server hostname: ${HOSTN:-unknown}"
  local TS_IP; TS_IP="$(rsh 'command -v tailscale >/dev/null 2>&1 && tailscale ip -4 2>/dev/null | head -n1' 2>/dev/null)"
  if [ -n "$TS_IP" ]; then ok "server tailnet IP: $TS_IP"
  else warn "server has no detectable Tailscale IP (tailscale not up there?)"; fi

  if inproj 'test -d .git && echo yes' 2>/dev/null | grep -q yes; then
    ok "AlphaLab checkout found at $PROJ"
  else
    err "no AlphaLab git checkout at $PROJ on the server"
    print "  Bootstrap it:  ssh $TARGET '/bin/zsh -c \"\$(curl -fsSL https://raw.githubusercontent.com/Pak209/AlphaLabs/main/scripts/bootstrap_old_mac_from_github.sh)\"'"
    exit 1
  fi
  if inproj 'test -x .venv/bin/python && echo yes' 2>/dev/null | grep -q yes; then
    ok "server virtualenv present"
  else
    warn "server virtualenv missing — run: ./ops deploy (or scripts/setup_old_mac.sh on the server)"
  fi
  print ""
  ok "doctor complete. If all green, remote operations are ready."
}

cmd_remote_status() {
  load_conf; require_reachable
  step "Remote status: $TARGET"
  local REPORT
  REPORT="$(inproj '
    echo "HOST $(scutil --get LocalHostName 2>/dev/null || hostname -s)"
    echo "TIME $(date "+%Y-%m-%d %H:%M:%S %Z")"
    echo "UP $(uptime | sed "s/.*up //; s/,.*users.*//")"
    echo "COMMIT $(git rev-parse --short HEAD 2>/dev/null) $(git branch --show-current 2>/dev/null)"
    echo "DIRTY $(git status --porcelain 2>/dev/null | wc -l | tr -d " ")"
    command -v tailscale >/dev/null 2>&1 && echo "TSIP $(tailscale ip -4 2>/dev/null | head -n1)"
    for L in '"${AGENTS[*]}"'; do
      S="$(launchctl print gui/$(id -u)/$L 2>/dev/null | awk -F"= " "/state =/{print \$2; exit}")"
      echo "AGENT $L ${S:-NOT_LOADED}"
    done
  ')" || { err "status query failed"; exit 1; }

  ok "reachable over SSH"
  print -r -- "$REPORT" | awk '
    $1=="HOST"  {printf "  host:    %s\n",$2}
    $1=="TIME"  {$1="";sub(/^ /,"");printf "  time:    %s\n",$0}
    $1=="UP"    {$1="";sub(/^ /,"");printf "  uptime:  %s\n",$0}
    $1=="COMMIT"{printf "  commit:  %s (%s)\n",$2,$3}
    $1=="DIRTY"{ if($2=="0") printf "  tree:    clean\n"; else printf "  tree:    %s uncommitted change(s)\n",$2}
    $1=="TSIP"  {printf "  tailnet: %s\n",$2}
    $1=="AGENT" {printf "  agent:   %-32s %s\n",$2,$3}
  '
  # Scheduler heartbeat (proves the always-on writer is alive on the same DB).
  # Parse the server's own db_status JSON remotely — no local python involved.
  local HBAT
  HBAT="$(inproj '.venv/bin/python -m alpha_lab.db_status --json 2>/dev/null' \
            | sed -n 's/.*"scheduler_heartbeat_at": *"\{0,1\}\([^",]*\).*/\1/p' | head -n1)"
  if [ -n "$HBAT" ] && [ "$HBAT" != "null" ]; then ok "scheduler heartbeat: $HBAT"
  else warn "no scheduler heartbeat yet"; fi
  print ""
  cmd_safety_status
}

cmd_health() {
  load_conf; require_reachable
  step "Full runtime health check (server-side verifier)"
  print "Running scripts/verify_old_mac_runtime.sh on $TARGET …\n"
  rsh_tty "cd \"$PROJ\" && ./scripts/verify_old_mac_runtime.sh"
}

cmd_deploy_preflight() {
  load_conf; require_reachable
  step "Deploy preflight (read-only)"
  local LOCAL_HEAD LOCAL_SHORT LOCAL_BRANCH LOCAL_DIRTY
  LOCAL_HEAD="$(git -C "$OPS_DIR" rev-parse HEAD 2>/dev/null || true)"
  LOCAL_SHORT="$(git -C "$OPS_DIR" rev-parse --short HEAD 2>/dev/null || true)"
  LOCAL_BRANCH="$(git -C "$OPS_DIR" branch --show-current 2>/dev/null || true)"
  LOCAL_DIRTY="$(git -C "$OPS_DIR" status --porcelain 2>/dev/null | wc -l | tr -d " ")"

  local REMOTE_REPORT
  REMOTE_REPORT="$(inproj '
    echo "remote_head=$(git rev-parse HEAD 2>/dev/null)"
    echo "remote_short=$(git rev-parse --short HEAD 2>/dev/null)"
    echo "remote_branch=$(git branch --show-current 2>/dev/null)"
    echo "remote_dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d " ")"
  ')" || die "could not read remote git state"
  local REMOTE_HEAD REMOTE_SHORT REMOTE_BRANCH REMOTE_DIRTY
  REMOTE_HEAD="$(print -r -- "$REMOTE_REPORT" | awk -F= '$1=="remote_head"{print $2; exit}')"
  REMOTE_SHORT="$(print -r -- "$REMOTE_REPORT" | awk -F= '$1=="remote_short"{print $2; exit}')"
  REMOTE_BRANCH="$(print -r -- "$REMOTE_REPORT" | awk -F= '$1=="remote_branch"{print $2; exit}')"
  REMOTE_DIRTY="$(print -r -- "$REMOTE_REPORT" | awk -F= '$1=="remote_dirty"{print $2; exit}')"

  local SAFETY; SAFETY="$(remote_safety_kv)" || die "could not read scheduler safety status"
  local CAN_TRIGGER SAFE_MODE
  CAN_TRIGGER="$(print -r -- "$SAFETY" | awk -F= '$1=="paper_trades_can_be_triggered_by_scheduler"{print $2; exit}')"
  SAFE_MODE="$(print -r -- "$SAFETY" | awk -F= '$1=="safe_stabilization_mode"{print $2; exit}')"

  print "  local:  ${LOCAL_SHORT:-unknown} (${LOCAL_BRANCH:-detached}), dirty=${LOCAL_DIRTY:-unknown}"
  print "  remote: ${REMOTE_SHORT:-unknown} (${REMOTE_BRANCH:-detached}), dirty=${REMOTE_DIRTY:-unknown}"
  if [ -n "$LOCAL_HEAD" ] && [ -n "$REMOTE_HEAD" ] && [ "$LOCAL_HEAD" = "$REMOTE_HEAD" ]; then
    ok "code parity: local HEAD matches old Mac"
  else
    warn "code gap: local HEAD differs from old Mac"
  fi
  if [ "${LOCAL_DIRTY:-0}" = "0" ]; then ok "local checkout clean"
  else warn "local checkout has ${LOCAL_DIRTY} uncommitted change(s); commit safe changes before deploy"; fi
  if [ "${REMOTE_DIRTY:-0}" = "0" ]; then ok "old Mac checkout clean"
  else warn "old Mac checkout has ${REMOTE_DIRTY} uncommitted change(s); bootstrap deploy will refuse to pull"; fi
  if [ "$SAFE_MODE" = "true" ]; then ok "safe stabilization mode is true"
  else warn "safe stabilization mode is false"; fi
  if [ "$CAN_TRIGGER" = "true" ]; then
    err "deploy blocked: scheduler paper jobs can trigger Alpaca PAPER orders"
    print "  Next safe step: switch ALPHALAB_SCHEDULER_MODE=dry_run on the old Mac, restart scheduler intentionally, then rerun ./ops deploy-preflight."
    exit 1
  fi
  if [ "${LOCAL_DIRTY:-0}" != "0" ] || [ "${REMOTE_DIRTY:-0}" != "0" ]; then
    warn "deploy not ready: resolve dirty checkout(s) first"
    exit 1
  fi
  ok "deploy preflight passed. Next command would be: ./ops deploy"
}

cmd_deploy() {
  load_conf; require_reachable
  step "Deploy (GitHub ff-only pull on the server)"
  require_safe_service_reload "deploy/reload services"
  local BEFORE; BEFORE="$(inproj 'git rev-parse --short HEAD 2>/dev/null')"
  print "  target:        $TARGET"
  print "  project:       $PROJ"
  print "  current commit: ${BEFORE:-unknown}"
  print "  action:        bootstrap (git fetch + pull --ff-only + pip), reload services, verify"
  print "  PRESERVED:     .env, database, logs, reports, launchd config (never touched)"
  confirm "Proceed with deploy?" || exit 0

  step "1/3 — pull + dependencies (scripts/bootstrap_old_mac_from_github.sh)"
  if ! rsh_tty "cd \"$PROJ\" && ./scripts/bootstrap_old_mac_from_github.sh"; then
    err "bootstrap failed (dirty checkout, fetch error, or pip failure). Nothing reloaded."
    exit 1
  fi
  local AFTER; AFTER="$(inproj 'git rev-parse --short HEAD 2>/dev/null')"

  step "2/3 — reload always-on services"
  inproj "launchctl kickstart -k gui/\$(id -u)/com.alphalab.dashboard 2>/dev/null; \
          launchctl kickstart -k gui/\$(id -u)/com.alphalab.scheduler 2>/dev/null; echo reloaded" \
    && ok "dashboard + scheduler kickstarted" || warn "kickstart returned non-zero (check ./ops status)"

  step "3/3 — post-deploy verification"
  rsh_tty "cd \"$PROJ\" && ./scripts/verify_old_mac_runtime.sh"

  step "Deployment summary"
  ok "commit: ${BEFORE:-unknown} -> ${AFTER:-unknown}"
  print "  API:       ./ops api-status"
  print "  scheduler: ./ops scheduler-status"
  print "  database:  ./ops db-info"
}

# --- logs ------------------------------------------------------------------
_log_paths() {
  case "${1:-}" in
    scheduler) print "logs/scheduler.log logs/launchd_scheduler.err.log" ;;
    api)       print "logs/dashboard.err.log logs/dashboard.out.log" ;;
    errors)    print "logs/dashboard.err.log logs/launchd_scheduler.err.log logs/launchd_options_validation.err.log" ;;
    *)         print "" ;;
  esac
}

cmd_logs() {
  load_conf; require_reachable
  local which="${1:-scheduler}"
  local paths; paths="$(_log_paths "$which")"
  [ -n "$paths" ] || die "unknown log target '$which' (use: scheduler | api | errors)"
  local n="${2:-60}"
  step "logs ($which): last $n lines from $TARGET"
  inproj "for f in $paths; do [ -f \"\$f\" ] && { echo \"----- \$f -----\"; tail -n $n \"\$f\"; }; done; true"
}

cmd_tail() {
  load_conf; require_reachable
  local which="${1:-scheduler}"
  local file
  case "$which" in
    scheduler) file="logs/scheduler.log" ;;
    api)       file="logs/dashboard.err.log" ;;
    *) die "unknown tail target '$which' (use: scheduler | api)" ;;
  esac
  step "tail -f $file on $TARGET (Ctrl-C to stop)"
  rsh_tty "cd \"$PROJ\" && touch \"$file\" 2>/dev/null; tail -n 40 -f \"$file\""
}

# --- focused status reads --------------------------------------------------
cmd_scheduler_status() {
  load_conf; require_reachable
  step "Scheduler status"
  inproj 'L=com.alphalab.scheduler
    S="$(launchctl print gui/$(id -u)/$L 2>/dev/null | awk -F"= " "/state =/{print \$2; exit}")"
    echo "agent: ${S:-NOT_LOADED}"
    .venv/bin/python -m alpha_lab.db_status --json 2>/dev/null \
      | sed -n "s/.*\"scheduler_heartbeat_at\": *\"\{0,1\}\([^\",]*\).*/heartbeat: \1/p" | head -n1
    echo "--- recent scheduler log ---"
    [ -f logs/scheduler.log ] && tail -n 15 logs/scheduler.log || echo "(no scheduler.log yet)"'
}

cmd_api_status() {
  load_conf; require_reachable
  step "API status (loopback http://127.0.0.1:${PORT} on the server)"
  inproj "code=\$(curl -sS --max-time 10 -o /tmp/ops_health.json -w '%{http_code}' http://127.0.0.1:${PORT}/api/health 2>/dev/null || echo 000)
    echo \"/api/health -> HTTP \$code\"
    [ \"\$code\" = 200 ] && cat /tmp/ops_health.json && echo
    dbc=\$(curl -sS --max-time 10 -o /dev/null -w '%{http_code}' http://127.0.0.1:${PORT}/api/db-status 2>/dev/null || echo 000)
    echo \"/api/db-status -> HTTP \$dbc\"
    cat=\$(curl -sS --max-time 10 -o /dev/null -w '%{http_code}' http://127.0.0.1:${PORT}/api/catalysts/intelligence 2>/dev/null || echo 000)
    echo \"/api/catalysts/intelligence -> HTTP \$cat\""
}

cmd_safety_status() {
  load_conf; require_reachable
  step "Scheduler safety status"
  local SAFETY; SAFETY="$(remote_safety_kv)" || die "could not read scheduler safety status"
  local MODE ARMED PAPER_ENABLED CAN_TRIGGER SAFE
  MODE="$(print -r -- "$SAFETY" | awk -F= '$1=="scheduler_mode"{print $2; exit}')"
  ARMED="$(print -r -- "$SAFETY" | awk -F= '$1=="automation_paper_trading_armed"{print $2; exit}')"
  PAPER_ENABLED="$(print -r -- "$SAFETY" | awk -F= '$1=="scheduler_paper_jobs_enabled"{print $2; exit}')"
  CAN_TRIGGER="$(print -r -- "$SAFETY" | awk -F= '$1=="paper_trades_can_be_triggered_by_scheduler"{print $2; exit}')"
  SAFE="$(print -r -- "$SAFETY" | awk -F= '$1=="safe_stabilization_mode"{print $2; exit}')"
  echo "  ALPHALAB_SCHEDULER_MODE: $MODE"
  echo "  automation paper trading armed: $ARMED"
  echo "  scheduler paper jobs enabled: $PAPER_ENABLED"
  echo "  paper trades can be triggered by scheduler jobs: $CAN_TRIGGER"
  echo "  safe stabilization mode: $SAFE"
  if [ "$SAFE" = true ]; then
    echo "  recommendation: safe for stabilization: scheduler dry_run and automation paper-trade guard disarmed"
  elif [ "$CAN_TRIGGER" = true ]; then
    echo "  recommendation: paper orders are armed: switch ALPHALAB_SCHEDULER_MODE=dry_run for stabilization unless this is intentional"
  elif [ "$MODE" = "paper" ]; then
    echo "  recommendation: scheduler is paper but automation paper-trade guard is disarmed; switch ALPHALAB_SCHEDULER_MODE=dry_run for stabilization clarity"
  else
    echo "  recommendation: scheduler is dry_run but automation paper-trade guard is armed; unset ALPHALAB_ALLOW_AUTOMATION_PAPER_TRADES for stabilization"
  fi
}

cmd_db_info() {
  load_conf; require_reachable
  step "Database info (server-resolved path + live counts)"
  inproj '.venv/bin/python -m alpha_lab.db_status'
}

cmd_strategy_audit() {
  load_conf; require_reachable
  step "Strategy attribution audit (read-only)"
  inproj '.venv/bin/python - <<'"'"'PY'"'"'
import json
import os
import sqlite3
from pathlib import Path

try:
    from alpha_lab.env import load_dotenv
    from alpha_lab.database import resolve_db_path
except Exception as exc:
    print(f"failed to import AlphaLab helpers: {exc}")
    raise SystemExit(1)

load_dotenv()
db_path = Path(resolve_db_path()).expanduser().resolve()
conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
conn.row_factory = sqlite3.Row
with conn:
    total_ideas = conn.execute("SELECT COUNT(*) FROM alpha_ideas").fetchone()[0]
    total_trades = conn.execute("SELECT COUNT(*) FROM trades").fetchone()[0]
    total_strategies = conn.execute("SELECT COUNT(*) FROM strategies").fetchone()[0]
    ideas_missing = conn.execute("""
        SELECT COUNT(*)
        FROM alpha_ideas i
        LEFT JOIN idea_strategies ix ON ix.idea_id = i.id
        WHERE ix.strategy_id IS NULL
    """).fetchone()[0]
    trades_missing = conn.execute("""
        SELECT COUNT(*)
        FROM trades t
        LEFT JOIN idea_strategies ix ON ix.idea_id = t.idea_id
        WHERE ix.strategy_id IS NULL
    """).fetchone()[0]
    orphan_links = conn.execute("""
        SELECT COUNT(*)
        FROM idea_strategies ix
        LEFT JOIN alpha_ideas i ON i.id = ix.idea_id
        LEFT JOIN strategies s ON s.id = ix.strategy_id
        WHERE i.id IS NULL OR s.id IS NULL
    """).fetchone()[0]
    sample_ideas = [dict(row) for row in conn.execute("""
        SELECT i.id, i.ticker, i.source, i.status, i.created_at
        FROM alpha_ideas i
        LEFT JOIN idea_strategies ix ON ix.idea_id = i.id
        WHERE ix.strategy_id IS NULL
        ORDER BY i.id DESC
        LIMIT 5
    """).fetchall()]
    sample_trades = [dict(row) for row in conn.execute("""
        SELECT t.id, t.idea_id, t.ticker, t.status, t.dry_run, t.opened_at
        FROM trades t
        LEFT JOIN idea_strategies ix ON ix.idea_id = t.idea_id
        WHERE ix.strategy_id IS NULL
        ORDER BY t.id DESC
        LIMIT 5
    """).fetchall()]
status = "ok" if ideas_missing == 0 and trades_missing == 0 and orphan_links == 0 else "needs_attention"
print(f"  status:                         {status}")
print(f"  read only:                      true")
print(f"  db path:                        {db_path}")
print(f"  total ideas:                    {total_ideas}")
print(f"  total trades:                   {total_trades}")
print(f"  total strategies:               {total_strategies}")
print(f"  ideas missing strategy labels:  {ideas_missing}")
print(f"  trades missing strategy labels: {trades_missing}")
print(f"  orphan strategy links:          {orphan_links}")
if sample_ideas:
    print("  sample ideas missing labels:")
    for row in sample_ideas:
        print("    " + json.dumps(row, sort_keys=True))
if sample_trades:
    print("  sample trades missing labels:")
    for row in sample_trades:
        print("    " + json.dumps(row, sort_keys=True))
raise SystemExit(0 if status == "ok" else 1)
PY'
}

cmd_agent_status() {
  load_conf; require_reachable
  step "Agent / scanner status (read-only)"
  inproj '.venv/bin/python - <<'"'"'PY'"'"'
import json
import sqlite3
from datetime import datetime
from pathlib import Path
from zoneinfo import ZoneInfo

from alpha_lab.database import resolve_db_path
from alpha_lab.env import load_dotenv
from alpha_lab.scheduler import build_scheduler

load_dotenv()
db_path = Path(resolve_db_path()).expanduser().resolve()
conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
conn.row_factory = sqlite3.Row

def payload(raw):
    try:
        data = json.loads(raw or "{}")
    except Exception:
        return {"status": "error", "error_message": "invalid payload_json"}
    return data if isinstance(data, dict) else {"status": "error", "error_message": "non-object payload_json"}

def status_of(data):
    value = str(data.get("status") or "").strip().lower()
    if value:
        return value
    if data.get("source_problems"):
        return "warning"
    if data.get("error") or data.get("error_message"):
        return "error"
    return "ok"

def items_created(data):
    for key in ("ideas_persisted", "items_created", "orders_created", "candidates_found", "raw_items"):
        value = data.get(key)
        if isinstance(value, (int, float)):
            return int(value)
    return 0

with conn:
    rows = conn.execute("""
        SELECT source, run_type, payload_json, created_at
        FROM scanner_runs
        ORDER BY datetime(created_at) DESC, id DESC
        LIMIT 20
    """).fetchall()

print(f"  db path: {db_path}")
print("  recent scanner runs:")
for row in rows:
    data = payload(row["payload_json"])
    err = data.get("error_message") or data.get("error") or data.get("reason") or ""
    if not err and data.get("source_problems"):
        err = json.dumps(data["source_problems"], sort_keys=True, default=str)
    agent = row["source"]
    run_type = row["run_type"]
    created_at = row["created_at"]
    last_started_at = data.get("started_at") or data.get("timestamp") or created_at
    last_finished_at = data.get("finished_at") or created_at
    status = status_of(data)
    created = items_created(data)
    duration_ms = data.get("duration_ms")
    print(
        "    "
        f"agent={agent} "
        f"run_type={run_type} "
        f"last_started_at={last_started_at} "
        f"last_finished_at={last_finished_at} "
        f"status={status} "
        f"items_created={created} "
        f"duration_ms={duration_ms} "
        f"error_message={err}"
    )

scheduler = build_scheduler(service=object())
now = datetime.now(ZoneInfo("America/Los_Angeles"))
jobs = scheduler.get_jobs()
print(f"  scheduler_job_count: {len(jobs)}")
for job in jobs:
    next_run = job.trigger.get_next_fire_time(None, now)
    next_run_text = next_run.isoformat() if next_run else ""
    print(f"    job={job.id} next_run_time={next_run_text} trigger={job.trigger}")
try:
    scheduler.shutdown(wait=False)
except Exception:
    pass
PY'
}

cmd_production_audit() {
  load_conf
  step "Production audit (read-only)"
  local DAY_LOCAL; DAY_LOCAL="$(date +%F)"

  # 1) reachability ---------------------------------------------------------
  local REACHABLE=1
  rsh "echo ok" >/dev/null 2>&1 || REACHABLE=0

  local INFRA="" METRICS=""
  local SERVER_TIME="" COMMIT="" DASH="UNREACHABLE" SCHED="UNREACHABLE"
  local API_CODE="000" API_DB="" HEARTBEAT="" RATE_HITS="0" RES_DB=""

  if [ "$REACHABLE" -eq 1 ]; then
    # 2)+3) infra: agent states, loopback API health + db_path, heartbeat, log rate-limit hits
    INFRA="$(inproj '
      echo "server_time=$(date "+%Y-%m-%d %H:%M:%S %Z")"
      echo "commit=$(git rev-parse --short HEAD 2>/dev/null)"
      for L in com.alphalab.dashboard com.alphalab.scheduler; do
        S="$(launchctl print gui/$(id -u)/$L 2>/dev/null | awk -F"= " "/state =/{print \$2; exit}")"
        echo "agent_${L}=${S:-NOT_LOADED}"
      done
      code=$(curl -sS --max-time 10 -o /tmp/ops_audit_health.json -w "%{http_code}" http://127.0.0.1:'"$PORT"'/api/health 2>/dev/null || echo 000)
      echo "api_health_code=$code"
      echo "api_db_path=$(sed -n "s/.*\"db_path\": *\"\([^\"]*\)\".*/\1/p" /tmp/ops_audit_health.json 2>/dev/null | head -n1)"
      echo "heartbeat=$(.venv/bin/python -m alpha_lab.db_status --json 2>/dev/null | sed -n "s/.*\"scheduler_heartbeat_at\": *\"\{0,1\}\([^\",]*\).*/\1/p" | head -n1)"
      rl=$(grep -Eic "rate.?limit|429|too many requests" logs/dashboard.err.log logs/dashboard.out.log logs/scheduler.log 2>/dev/null | awk -F: "{s+=\$2} END{print s+0}")
      echo "rate_limit_hits=$rl"
      true
    ')" || INFRA=""
    # 4)-10) data side: read-only DB + automation posture (no secrets)
    METRICS="$(inproj '.venv/bin/python -m alpha_lab.production_audit --format kv 2>/dev/null')" || METRICS=""

    SERVER_TIME="$(_kv_get "$INFRA" server_time)"
    COMMIT="$(_kv_get "$INFRA" commit)"
    DASH="$(_kv_get "$INFRA" agent_com.alphalab.dashboard)"; DASH="${DASH:-NOT_LOADED}"
    SCHED="$(_kv_get "$INFRA" agent_com.alphalab.scheduler)"; SCHED="${SCHED:-NOT_LOADED}"
    API_CODE="$(_kv_get "$INFRA" api_health_code)"; API_CODE="${API_CODE:-000}"
    API_DB="$(_kv_get "$INFRA" api_db_path)"
    HEARTBEAT="$(_kv_get "$INFRA" heartbeat)"
    RATE_HITS="$(_kv_get "$INFRA" rate_limit_hits)"; RATE_HITS="${RATE_HITS:-0}"
    RES_DB="$(_kv_get "$METRICS" db_path)"
  fi

  # data metrics (default to '?' so a failed read is obvious, never crashes) --
  local AUDIT_DAY DB_EXISTS POLY_TODAY POLY_TOTAL POLY_LATEST SEC_TODAY SEC_TOTAL SEC_LATEST
  local IDEAS_TODAY PAPER_TRADES DRY_TRADES PAPER_ORDERS PAPER_ORDERS_ID REJECTS BROKER_UNAVAIL
  local SCANNER_ERRS RADAR_RUNS MODE ARMED CANTRIG
  AUDIT_DAY="$(_kv_get "$METRICS" audit_day)"
  DB_EXISTS="$(_kv_get "$METRICS" db_exists)"
  POLY_TODAY="$(_kv_get "$METRICS" polygon_today)";  POLY_TOTAL="$(_kv_get "$METRICS" polygon_total)";  POLY_LATEST="$(_kv_get "$METRICS" polygon_latest)"
  SEC_TODAY="$(_kv_get "$METRICS" sec_today)";        SEC_TOTAL="$(_kv_get "$METRICS" sec_total)";       SEC_LATEST="$(_kv_get "$METRICS" sec_latest)"
  IDEAS_TODAY="$(_kv_get "$METRICS" ideas_today)"
  PAPER_TRADES="$(_kv_get "$METRICS" paper_trades_today)"; DRY_TRADES="$(_kv_get "$METRICS" dry_run_trades_today)"
  PAPER_ORDERS="$(_kv_get "$METRICS" paper_orders_today)"; PAPER_ORDERS_ID="$(_kv_get "$METRICS" paper_orders_with_broker_id)"
  REJECTS="$(_kv_get "$METRICS" rejects_today)"; BROKER_UNAVAIL="$(_kv_get "$METRICS" broker_unavailable_today)"
  SCANNER_ERRS="$(_kv_get "$METRICS" scanner_errors_today)"; RADAR_RUNS="$(_kv_get "$METRICS" catalyst_radar_runs_today)"
  MODE="$(_kv_get "$METRICS" scheduler_mode)"; ARMED="$(_kv_get "$METRICS" paper_trades_armed)"; CANTRIG="$(_kv_get "$METRICS" paper_trades_can_trigger)"

  # status determination ----------------------------------------------------
  local -a RED YELLOW
  if [ "$REACHABLE" -eq 0 ]; then
    RED+=("server unreachable over SSH/Tailscale")
  else
    [ "$DASH" = "running" ]  || RED+=("dashboard LaunchAgent not running (state=${DASH})")
    [ "$SCHED" = "running" ] || RED+=("scheduler LaunchAgent not running (state=${SCHED})")
    [ "$API_CODE" = "200" ]  || RED+=("loopback API unhealthy (/api/health HTTP ${API_CODE})")
    if [ -z "$METRICS" ]; then
      YELLOW+=("could not read DB audit metrics (python module returned nothing)")
    else
      [ "$DB_EXISTS" = "true" ] || RED+=("resolved DB file does not exist on server")
      if [ -n "$RES_DB" ] && [ -n "$API_DB" ] && [ "$RES_DB" != "$API_DB" ]; then
        RED+=("split-brain DB: resolver=${RES_DB} vs API=${API_DB}")
      fi
    fi
    [ -n "$HEARTBEAT" ] || YELLOW+=("no scheduler heartbeat recorded")
    [ "${RATE_HITS:-0}" = "0" ] || YELLOW+=("${RATE_HITS} rate-limit/429 mention(s) in recent logs")
  fi
  # data-derived yellow reasons emitted by the module
  local DR; DR="$(print -r -- "$METRICS" | sed -n 's/^data_reason=//p')"
  if [ -n "$DR" ]; then
    while IFS= read -r r; do [ -n "$r" ] && YELLOW+=("$r"); done <<< "$DR"
  fi

  local STATUS
  if   [ ${#RED[@]}    -gt 0 ]; then STATUS="RED"
  elif [ ${#YELLOW[@]} -gt 0 ]; then STATUS="YELLOW"
  else STATUS="GREEN"; fi

  # render markdown report --------------------------------------------------
  local DAY="${AUDIT_DAY:-$DAY_LOCAL}"
  local OUTDIR="$OPS_DIR/reports/production_audit"
  mkdir -p "$OUTDIR"
  local OUT="$OUTDIR/$DAY.md"

  {
    print -r -- "# AlphaLabs Production Audit — ${DAY}"
    print -r -- ""
    print -r -- "- Status: **${STATUS}**"
    print -r -- "- Generated: $(date '+%Y-%m-%d %H:%M:%S %Z') (dev Mac) for server day ${DAY}"
    print -r -- "- Server: ${TARGET} — ${SERVER_TIME:-unreachable} — commit ${COMMIT:-?}"
    print -r -- "- Read-only: no trades placed, no .env/DB/code modified, no secrets printed."
    print -r -- ""
    print -r -- "## Status"
    print -r -- ""
    case "$STATUS" in
      GREEN)  print -r -- "**GREEN** — data gathered today and core system healthy." ;;
      YELLOW) print -r -- "**YELLOW** — system reachable but partial ingestion / no trades / needs attention." ;;
      RED)    print -r -- "**RED** — a core path (server / scheduler / API / DB) is broken." ;;
    esac
    print -r -- ""
    print -r -- "## Checks"
    print -r -- ""
    print -r -- "| # | Check | Result |"
    print -r -- "| - | ----- | ------ |"
    print -r -- "| 1 | Server reachable over Tailscale/SSH | $([ "$REACHABLE" -eq 1 ] && echo yes || echo NO) |"
    print -r -- "| 2 | Dashboard / scheduler running | dashboard=${DASH} · scheduler=${SCHED} |"
    print -r -- "| 3 | Resolver/API DB match | resolver=\`${RES_DB:-?}\` · api=\`${API_DB:-?}\` · heartbeat=${HEARTBEAT:-none} |"
    print -r -- "| 4 | Polygon gathered alpha today | ${POLY_TODAY:-?} (total ${POLY_TOTAL:-?}, latest ${POLY_LATEST:-none}) |"
    print -r -- "| 5 | SEC EDGAR gathered alpha today | ${SEC_TODAY:-?} (total ${SEC_TOTAL:-?}, latest ${SEC_LATEST:-none}) |"
    print -r -- "| 6 | Ideas generated today | ${IDEAS_TODAY:-?} |"
    print -r -- "| 7 | Paper trades submitted today | ${PAPER_TRADES:-?} trades · ${PAPER_ORDERS:-?} orders (${PAPER_ORDERS_ID:-?} w/ broker id) |"
    print -r -- "| 8 | Ideas → trades today | see table below |"
    print -r -- "| 9 | Rejects / errors / rate limits | rejects=${REJECTS:-?} · broker_unavailable=${BROKER_UNAVAIL:-?} · scanner_errors=${SCANNER_ERRS:-?} · rate_limit_log_hits=${RATE_HITS} |"
    print -r -- "| 10 | Automation mode | mode=${MODE:-?} · paper_armed=${ARMED:-?} · can_trigger=${CANTRIG:-?} |"
    print -r -- ""
    print -r -- "## Ideas that became trades today"
    print -r -- ""
    local TLINES; TLINES="$(print -r -- "$METRICS" | sed -n 's/^trade=//p')"
    if [ -n "$TLINES" ]; then
      print -r -- "| Ticker | Mode | Idea source | Catalyst source | Status | Broker order |"
      print -r -- "| ------ | ---- | ----------- | --------------- | ------ | ------------ |"
      while IFS='|' read -r tk md isrc csrc st bk; do
        [ -n "$tk" ] && print -r -- "| ${tk} | ${md} | ${isrc} | ${csrc} | ${st} | ${bk} |"
      done <<< "$TLINES"
    else
      print -r -- "_No trades opened today._"
    fi
    print -r -- ""
    print -r -- "## Blockers"
    print -r -- ""
    if [ ${#RED[@]} -gt 0 ]; then
      for x in "${RED[@]}"; do print -r -- "- RED: ${x}"; done
    fi
    if [ ${#YELLOW[@]} -gt 0 ]; then
      for x in "${YELLOW[@]}"; do print -r -- "- YELLOW: ${x}"; done
    fi
    [ ${#RED[@]} -eq 0 ] && [ ${#YELLOW[@]} -eq 0 ] && print -r -- "None."
    print -r -- ""
    if [ "$CANTRIG" = "true" ]; then
      print -r -- "## Next safest fix"
      print -r -- ""
      print -r -- "Scheduler can trigger Alpaca **paper** orders (mode=paper, armed=true). If this is"
      print -r -- "not intended, set \`ALPHALAB_SCHEDULER_MODE=dry_run\` in the server .env and run"
      print -r -- "\`./ops restart\`. This audit changed nothing."
      print -r -- ""
    fi
  } > "$OUT"

  # concise terminal summary ------------------------------------------------
  case "$STATUS" in
    GREEN)  ok   "STATUS: GREEN — data gathered today and system healthy" ;;
    YELLOW) warn "STATUS: YELLOW — partial ingestion / no trades / attention" ;;
    RED)    err  "STATUS: RED — core path broken" ;;
  esac
  print "  server:    ${SERVER_TIME:-unreachable}   commit=${COMMIT:-?}"
  print "  agents:    dashboard=${DASH}  scheduler=${SCHED}   API /api/health HTTP ${API_CODE}"
  print "  DB:        resolver=${RES_DB:-?}"
  print "             api=${API_DB:-?}   heartbeat=${HEARTBEAT:-none}"
  print "  Polygon:   today=${POLY_TODAY:-?}  (total ${POLY_TOTAL:-?}, latest ${POLY_LATEST:-none})"
  print "  SEC EDGAR: today=${SEC_TODAY:-?}  (total ${SEC_TOTAL:-?}, latest ${SEC_LATEST:-none})"
  print "  ideas today=${IDEAS_TODAY:-?}   paper trades=${PAPER_TRADES:-?} (orders ${PAPER_ORDERS:-?}, broker-id ${PAPER_ORDERS_ID:-?})   dry-run trades=${DRY_TRADES:-?}"
  print "  rejects=${REJECTS:-?}  broker_unavailable=${BROKER_UNAVAIL:-?}  scanner_errors=${SCANNER_ERRS:-?}  rate_limit_log_hits=${RATE_HITS}"
  print "  automation: mode=${MODE:-?}  paper_armed=${ARMED:-?}  can_trigger=${CANTRIG:-?}"
  if [ ${#RED[@]} -gt 0 ]; then print ""; err "blockers:"; for x in "${RED[@]}"; do print "    - $x"; done; fi
  if [ ${#YELLOW[@]} -gt 0 ]; then print ""; warn "notes:"; for x in "${YELLOW[@]}"; do print "    - $x"; done; fi
  print ""
  ok "report saved: ${OUT#$OPS_DIR/}"
  [ "$STATUS" = "RED" ] && return 1 || return 0
}

# --- runtime provider checks (no secrets printed) --------------------------
cmd_check() {
  load_conf; require_reachable
  local provider="${1:-}"
  [ -n "$provider" ] || die "usage: ./ops check <polygon|sec|alpaca>"
  step "Runtime check: $provider (key presence + endpoint reachability; secrets hidden)"
  case "$provider" in
    polygon)
      inproj 'set -a; [ -f .env ] && source .env; set +a
        [ -n "${POLYGON_API_KEY:-}" ] && echo "POLYGON_API_KEY: present (hidden)" || echo "POLYGON_API_KEY: MISSING"
        code=$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" "https://api.polygon.io/v1/marketstatus/now?apiKey=${POLYGON_API_KEY}" 2>/dev/null || echo 000)
        echo "api.polygon.io -> HTTP $code (200/401/403 = reachable)"'
      ;;
    sec)
      inproj 'set -a; [ -f .env ] && source .env; set +a
        [ -n "${SEC_USER_AGENT:-}" ] && echo "SEC_USER_AGENT: present" || echo "SEC_USER_AGENT: MISSING"
        code=$(curl -sS --max-time 10 -A "${SEC_USER_AGENT:-AlphaLab/0.1}" -o /dev/null -w "%{http_code}" "https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&type=8-K&output=atom" 2>/dev/null || echo 000)
        echo "www.sec.gov -> HTTP $code (200 = reachable)"'
      ;;
    alpaca)
      inproj "$_ALPACA_PAPER_GUARD_SH"'
        set -a; [ -f .env ] && source .env; set +a
        [ -n "${ALPACA_API_KEY:-}" ] && echo "ALPACA_API_KEY: present (hidden)" || echo "ALPACA_API_KEY: MISSING"
        [ -n "${ALPACA_SECRET_KEY:-}" ] && echo "ALPACA_SECRET_KEY: present (hidden)" || echo "ALPACA_SECRET_KEY: MISSING"
        base="${ALPACA_PAPER_BASE_URL:-https://paper-api.alpaca.markets}"
        echo "base URL: $base"
        # Validate AND normalize the base BEFORE any credentialed request, so a
        # live/look-alike/arbitrary-path base never receives keys and the composed
        # account URL is always exactly <canonical>/v2/account (no double slash).
        if canon="$(_alpaca_paper_base_canonical "$base")"; then
          code=$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" \
            -H "APCA-API-KEY-ID: ${ALPACA_API_KEY}" -H "APCA-API-SECRET-KEY: ${ALPACA_SECRET_KEY}" \
            "$canon/v2/account" 2>/dev/null || echo 000)
          echo "$canon/v2/account -> HTTP $code (200 = authed paper account, 401/403 = reachable but check keys)"
        else
          echo "$base/v2/account -> SKIPPED (base URL is not the canonical Alpaca paper endpoint; refusing credentialed request, fail closed). Set ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets"
        fi'
      inproj 'set -a; [ -f .env ] && source .env; set +a
        data_code=$(curl -sS --max-time 10 -o /dev/null -w "%{http_code}" \
          -H "APCA-API-KEY-ID: ${ALPACA_API_KEY}" -H "APCA-API-SECRET-KEY: ${ALPACA_SECRET_KEY}" \
          "https://data.alpaca.markets/v2/stocks/SPY/quotes/latest" 2>/dev/null || echo 000)
        echo "data.alpaca.markets/v2/stocks/SPY/quotes/latest -> HTTP $data_code (200 = market data reachable, 401/403 = reachable but check entitlement/keys)"'
      ;;
    *) die "unknown provider '$provider' (use: polygon | sec | alpaca)" ;;
  esac
}

