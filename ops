#!/bin/zsh
#
# ops — single remote-operations interface for AlphaLab.
#
# Runs on the DEV Mac and drives the dedicated OLD Mac runtime server over
# Tailscale/SSH. It is a thin, read-mostly orchestrator: every action it takes
# is an EXISTING on-server capability (scripts/*.sh, alpha_lab.* diagnostics,
# launchctl, the loopback API). It changes no trading logic, scheduler logic,
# database schema, or runtime behavior.
#
# Connection comes from scripts/server.conf (git-ignored). It prefers
# TAILSCALE_HOST when set, so you can manage the server from anywhere on your
# tailnet; otherwise it falls back to SERVER_HOST (LAN/Bonjour).
#
# Safety: state-changing actions (deploy, start, stop, restart, reload) ask for
# confirmation. Pass --yes/-y to skip the prompt in trusted automation. ops
# NEVER overwrites the server's .env, database, logs, or launchd config — it only
# ever pulls code (git ff-only) and reloads services.
#
# Usage:
#   ./ops <command> [subcommand] [--yes]
#   ./ops help
#
set -u
emulate -L zsh
setopt pipefail

OPS_DIR="${0:A:h}"
CONF="$OPS_DIR/scripts/server.conf"
EXAMPLE="$OPS_DIR/scripts/server.conf.example"

# The always-on launchd services on the production Mac.
AGENTS=(com.alphalab.dashboard com.alphalab.scheduler com.alphalab.options-validation)
PORT="${ALPHALAB_PORT:-8787}"

ASSUME_YES=0

ok()   { print -P "%F{green}[OK]%f   $*"; }
warn() { print -P "%F{yellow}[WARN]%f $*"; }
err()  { print -P "%F{red}[FAIL]%f $*"; }
step() { print -P "\n%F{cyan}== $* ==%f"; }

die() { err "$*"; exit 1; }

# Read one value from a multi-line "key=value" blob (handles '=' in the value).
_kv_get() { print -r -- "$1" | awk -F= -v k="$2" '$1==k{sub(/^[^=]*=/,"");print;exit}'; }

# --- connection ------------------------------------------------------------
load_conf() {
  if [ ! -f "$CONF" ]; then
    err "missing $CONF"
    print "Create it once:  cp ${EXAMPLE#$OPS_DIR/} scripts/server.conf  (then edit host/user)"
    exit 1
  fi
  source "$CONF"
  : "${SERVER_USER:?set SERVER_USER in scripts/server.conf}"
  : "${REMOTE_PATH:=AlphaLab}"
  # Prefer the tailnet name/IP for from-anywhere management; fall back to LAN.
  REMOTE_HOST="${TAILSCALE_HOST:-${SERVER_HOST:-}}"
  [ -n "$REMOTE_HOST" ] || die "set TAILSCALE_HOST or SERVER_HOST in scripts/server.conf"
  TARGET="${SERVER_USER}@${REMOTE_HOST}"
  # Literal $HOME (expanded on the SERVER, not locally) + the configured subdir.
  PROJ='$HOME/'"$REMOTE_PATH"
}

# Run a one-shot command string on the server. Quiet connection, hard timeout.
rsh() { ssh -o ConnectTimeout=8 -o BatchMode=no "$TARGET" "$1"; }

# Run a command string with the working dir already inside the project.
inproj() { rsh "cd \"$PROJ\" 2>/dev/null || { echo '__NO_PROJECT__'; exit 7; }; $1"; }

# Interactive/streaming remote (for tail -f). Allocates a TTY.
rsh_tty() { ssh -t -o ConnectTimeout=8 "$TARGET" "$1"; }

confirm() {
  local prompt="$1"
  [ "$ASSUME_YES" -eq 1 ] && return 0
  print ""
  read "REPLY?${prompt} [y/N] "
  case "$REPLY" in y|Y|yes|YES) return 0 ;; *) warn "aborted; nothing changed."; return 1 ;; esac
}

require_reachable() {
  if ! rsh "echo ok" >/dev/null 2>&1; then
    err "cannot reach $TARGET over SSH."
    print "  - Is the old Mac awake and on the tailnet/LAN?"
    print "  - Is Remote Login on? (System Settings > General > Sharing > Remote Login)"
    print "  - Diagnose with:  ./ops doctor"
    exit 1
  fi
}

remote_safety_kv() {
  inproj 'set -a; [ -f .env ] && source .env; set +a
    mode="$(printf "%s" "${ALPHALAB_SCHEDULER_MODE:-dry_run}" | tr "[:upper:]" "[:lower:]" | xargs)"
    [ "$mode" = "paper" ] || mode="dry_run"
    armed="$(printf "%s" "${ALPHALAB_ALLOW_AUTOMATION_PAPER_TRADES:-}" | tr "[:upper:]" "[:lower:]" | xargs)"
    paper_guard_armed=false; [ "$armed" = "true" ] && paper_guard_armed=true
    scheduler_paper_jobs_enabled=false; [ "$mode" = "paper" ] && scheduler_paper_jobs_enabled=true
    can_trigger=false
    if [ "$scheduler_paper_jobs_enabled" = true ] && [ "$paper_guard_armed" = true ]; then can_trigger=true; fi
    safe_stabilization=false
    if [ "$mode" = "dry_run" ] && [ "$paper_guard_armed" = false ]; then safe_stabilization=true; fi
    echo "scheduler_mode=$mode"
    echo "automation_paper_trading_armed=$paper_guard_armed"
    echo "scheduler_paper_jobs_enabled=$scheduler_paper_jobs_enabled"
    echo "paper_trades_can_be_triggered_by_scheduler=$can_trigger"
    echo "safe_stabilization_mode=$safe_stabilization"'
}

require_safe_service_reload() {
  local action="$1"
  local SAFETY; SAFETY="$(remote_safety_kv)" || die "could not read scheduler safety status"
  local CAN_TRIGGER; CAN_TRIGGER="$(print -r -- "$SAFETY" | awk -F= '$1=="paper_trades_can_be_triggered_by_scheduler"{print $2; exit}')"
  local MODE; MODE="$(print -r -- "$SAFETY" | awk -F= '$1=="scheduler_mode"{print $2; exit}')"
  local ARMED; ARMED="$(print -r -- "$SAFETY" | awk -F= '$1=="automation_paper_trading_armed"{print $2; exit}')"
  if [ "$CAN_TRIGGER" = "true" ]; then
    err "refusing to ${action}: scheduler paper jobs are armed (mode=${MODE}, automation_paper_trading_armed=${ARMED})."
    print "  For stabilization, switch ALPHALAB_SCHEDULER_MODE=dry_run on the server and restart intentionally."
    print "  This command did not change services, .env, or the database."
    exit 1
  fi
}

